# Copy to .env and fill in real values. The server exits on startup if
# DATABASE_URL or JWT_SECRET is missing (see src/index.ts).

# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/edtech_dev?schema=public"

# Secret used to sign JWTs (use a long random string, min 32 chars)
JWT_SECRET="change-me-to-a-long-random-secret-min-32-chars"

# Frontend origin allowed by CORS (optional, defaults to http://localhost:5173)
CLIENT_URL="http://localhost:5173"

# Port the API listens on (optional, defaults to 3000)
PORT=3000

# Node environment (optional)
NODE_ENV="development"
